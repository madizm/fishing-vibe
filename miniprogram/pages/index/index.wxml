<!-- pages/index/index.wxml -->
<view class="root">

  <!-- ══ 地图区域 ══ -->
  <map
    id="fishingMap"
    class="map"
    longitude="{{longitude}}"
    latitude="{{latitude}}"
    scale="{{scale}}"
    markers="{{markers}}"
    enable-satellite="{{enableSatellite}}"
    show-location
    bindmarkertap="onMarkerTap"
  />

  <!-- ══ 右上角地图工具按钮 ══ -->
  <view class="map-toolbar">
    <view class="map-btn" bindtap="onFitAll">全部</view>
    <view class="map-btn" bindtap="onToggleMapType">{{mapTypeBtnText}}</view>
  </view>

  <!-- ══ 底部筛选面板 ══ -->
  <view class="panel {{panelCollapsed ? 'panel--collapsed' : ''}}">

    <!-- 面板头部（点击折叠/展开） -->
    <view class="panel-header" bindtap="onTogglePanel">
      <view class="panel-title">
        <text class="label-brand">寻鱼radar</text>
        <text class="summary">共 {{total}} 个 · 显示 {{visibleCount}} 个</text>
      </view>
      <text class="panel-arrow">{{panelCollapsed ? '▲' : '▼'}}</text>
    </view>

    <!-- 面板内容（折叠时隐藏） -->
    <view class="panel-body" wx:if="{{!panelCollapsed}}">

      <!-- 搜索框 -->
      <view class="filter-row">
        <view class="search-wrap">
          <input
            class="input"
            placeholder="搜索钓点 / 作者 / 鱼种"
            value="{{searchQuery}}"
            bindinput="onSearchInput"
            confirm-type="search"
          />
        </view>
      </view>

      <!-- 鱼种选择 -->
      <view class="filter-row">
        <picker mode="selector" range="{{fishPickerRange}}" bindchange="onFishChange">
          <view class="picker-display">
            <text>{{fishFilter || '全部鱼种'}}</text>
            <text class="picker-arrow">›</text>
          </view>
        </picker>
      </view>

      <!-- 可信度滑块 -->
      <view class="filter-row">
        <view class="slider-label">
          <text>最低可信度</text>
          <text class="slider-value">{{confidenceDisplay}}</text>
        </view>
        <slider
          min="0" max="1" step="0.1"
          value="{{confidenceFilter}}"
          activeColor="#1565C0"
          bindchange="onConfidenceChange"
          bindchanging="onConfidenceChange"
        />
      </view>

      <!-- 钓点列表 -->
      <scroll-view class="spot-list" scroll-y wx:if="{{spots.length > 0}}">
        <view
          wx:for="{{spots}}"
          wx:key="id"
          class="spot-card"
          data-idx="{{index}}"
          bindtap="onSpotTap"
        >
          <view class="spot-header">
            <text class="spot-name">{{item.place_name}}</text>
            <text class="spot-conf">{{item.confidence}}</text>
          </view>
          <view class="spot-title-text">{{item.title || '无标题'}}</view>
          <view class="tag-row">
            <text
              wx:for="{{item.fish_species}}"
              wx:for-item="fish"
              wx:key="fish"
              class="tag"
            >{{fish}}</text>
            <text wx:if="{{!item.fish_species || item.fish_species.length === 0}}" class="tag tag-gray">鱼种待补充</text>
          </view>
        </view>
      </scroll-view>

      <view class="empty-tip" wx:if="{{spots.length === 0}}">没有符合条件的钓点</view>

    </view>
  </view>

  <!-- ══ 钓点详情弹层 ══ -->
  <view class="detail-mask" wx:if="{{detailVisible}}" bindtap="onCloseDetail" />
  <view class="detail-sheet" wx:if="{{detailVisible && selectedSpot}}">
    <view class="detail-close" bindtap="onCloseDetail">✕</view>
    <view class="detail-name">{{selectedSpot.place_name}}</view>

    <view class="detail-row">
      <text class="detail-label">经纬度</text>
      <text class="detail-val">{{selectedSpot.lng}}, {{selectedSpot.lat}}</text>
    </view>
    <view class="detail-row">
      <text class="detail-label">地理级别</text>
      <text class="detail-val">{{selectedSpot.geocode_level || '-'}} / score {{selectedSpot.geocode_score || '-'}}</text>
    </view>
    <view class="detail-row">
      <text class="detail-label">可信度</text>
      <text class="detail-val">{{selectedSpot.confidence || '-'}}</text>
    </view>
    <view class="detail-row">
      <text class="detail-label">作者</text>
      <text class="detail-val">{{selectedSpot.author || '-'}}</text>
    </view>
    <view class="detail-row">
      <text class="detail-label">发布时间</text>
      <text class="detail-val">{{selectedSpot.publish_time || '-'}}</text>
    </view>

    <view class="detail-row detail-row--col">
      <text class="detail-label">鱼种</text>
      <view class="tag-row">
        <text
          wx:for="{{selectedSpot.fish_species}}"
          wx:for-item="fish"
          wx:key="fish"
          class="tag"
        >{{fish}}</text>
        <text wx:if="{{!selectedSpot.fish_species || selectedSpot.fish_species.length === 0}}" class="tag tag-gray">鱼种待补充</text>
      </view>
    </view>

    <view class="detail-row detail-row--col">
      <text class="detail-label">视频标题</text>
      <text class="detail-title-text">{{selectedSpot.title || '-'}}</text>
    </view>

    <view wx:if="{{selectedSpot.url}}" class="copy-btn" data-url="{{selectedSpot.url}}" bindtap="onOpenUrl">
      复制抖音链接
    </view>
  </view>

</view>
