/* pages/index/index.wxss */

/* ── 根容器（全屏，地图在下方，面板浮在上方） ── */
.root {
  position: relative;
  width: 100%;
  height: 100vh;
  overflow: hidden;
  background: #f4f7f6;
}

/* ── 地图 ── */
.map {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

/* ── 右上角地图工具 ── */
.map-toolbar {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  z-index: 10;
}
.map-btn {
  background: rgba(255, 255, 255, 0.92);
  color: #157a54;
  font-size: 24rpx;
  font-weight: 500;
  padding: 10rpx 18rpx;
  border-radius: 10rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.12);
  text-align: center;
}

/* ── 底部面板 ── */
.panel {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: #ffffff;
  border-radius: 28rpx 28rpx 0 0;
  box-shadow: 0 -4rpx 24rpx rgba(20, 35, 31, 0.14);
  z-index: 20;
  max-height: 60vh;
  display: flex;
  flex-direction: column;
  transition: max-height 0.2s ease;
}
.panel--collapsed {
  max-height: 100rpx;
}

.panel-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 28rpx 16rpx;
  flex-shrink: 0;
}
.panel-title {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}
.label-brand {
  font-size: 28rpx;
  font-weight: 500;
  color: #157a54;
}
.summary {
  font-size: 22rpx;
  color: #66736f;
}
.panel-arrow {
  font-size: 24rpx;
  color: #66736f;
}

.panel-body {
  flex: 1;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  padding: 0 20rpx 16rpx;
}

/* ── 筛选行 ── */
.filter-row {
  margin-bottom: 14rpx;
}
.input {
  width: 100%;
  background: #f4f7f6;
  border-radius: 16rpx;
  padding: 16rpx 20rpx;
  font-size: 26rpx;
  color: #14231f;
  border: 1rpx solid #dbe5e1;
  box-sizing: border-box;
}
.picker-display {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #f4f7f6;
  border: 1rpx solid #dbe5e1;
  border-radius: 16rpx;
  padding: 16rpx 20rpx;
  font-size: 26rpx;
  color: #14231f;
}
.picker-arrow {
  color: #66736f;
  font-size: 30rpx;
}
.slider-label {
  display: flex;
  justify-content: space-between;
  font-size: 24rpx;
  color: #30433d;
  margin-bottom: 4rpx;
}
.slider-value {
  color: #157a54;
  font-weight: 500;
}

/* ── 钓点列表 ── */
.spot-list {
  flex: 1;
  overflow-y: auto;
}
.spot-card {
  background: #ffffff;
  border: 1rpx solid #dbe5e1;
  border-radius: 18rpx;
  padding: 20rpx;
  margin-bottom: 12rpx;
}
.spot-header {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 8rpx;
}
.spot-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #14231f;
  flex: 1;
  margin-right: 10rpx;
}
.spot-conf {
  font-size: 22rpx;
  color: #157a54;
  white-space: nowrap;
}
.spot-title-text {
  font-size: 22rpx;
  color: #66736f;
  line-height: 1.45;
  margin-bottom: 10rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

/* ── 标签 ── */
.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 6rpx;
}
.tag {
  font-size: 22rpx;
  font-weight: 500;
  color: #116642;
  background: #e9f6ef;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
}
.tag-gray {
  color: #596863;
  background: #eef2f1;
}

.empty-tip {
  text-align: center;
  font-size: 26rpx;
  color: #66736f;
  padding: 40rpx 0;
}

/* ── 详情弹层 ── */
.detail-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.35);
  z-index: 30;
}
.detail-sheet {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #ffffff;
  border-radius: 28rpx 28rpx 0 0;
  padding: 36rpx 28rpx 60rpx;
  z-index: 40;
  max-height: 75vh;
  overflow-y: auto;
  box-shadow: 0 -4rpx 24rpx rgba(20, 35, 31, 0.18);
}
.detail-close {
  position: absolute;
  top: 24rpx;
  right: 28rpx;
  font-size: 32rpx;
  color: #66736f;
  padding: 10rpx;
}
.detail-name {
  font-size: 36rpx;
  font-weight: 500;
  color: #14231f;
  margin-bottom: 24rpx;
  padding-right: 60rpx;
}
.detail-row {
  display: flex;
  align-items: center;
  padding: 14rpx 0;
  border-bottom: 1rpx solid #f0f4f2;
}
.detail-row--col {
  flex-direction: column;
  align-items: flex-start;
  gap: 10rpx;
}
.detail-label {
  font-size: 24rpx;
  color: #66736f;
  width: 140rpx;
  flex-shrink: 0;
}
.detail-val {
  font-size: 26rpx;
  color: #14231f;
  flex: 1;
}
.detail-title-text {
  font-size: 24rpx;
  color: #344842;
  line-height: 1.55;
}
.copy-btn {
  margin-top: 28rpx;
  background: #157a54;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 500;
  text-align: center;
  padding: 22rpx;
  border-radius: 18rpx;
}
