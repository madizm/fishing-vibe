/* pages/index/index.wxss */

/* ── 根容器 ── */
.root {
  position: relative;
  width: 100%;
  height: 100vh;
  overflow: hidden;
  background: #0a1929;
}

/* ── 地图 ── */
.map {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

/* ── 右上角地图工具 ── */
.map-toolbar {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  z-index: 10;
}
.map-btn {
  background: rgba(255, 255, 255, 0.92);
  color: #1565C0;
  font-size: 24rpx;
  font-weight: 500;
  padding: 10rpx 18rpx;
  border-radius: 10rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.12);
  text-align: center;
}

/* ── 底部面板 ── */
.panel {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: #ffffff;
  border-radius: 28rpx 28rpx 0 0;
  box-shadow: 0 -4rpx 24rpx rgba(10, 25, 41, 0.18);
  z-index: 20;
  max-height: 60vh;
  display: flex;
  flex-direction: column;
  transition: max-height 0.2s ease;
}
.panel--collapsed {
  max-height: 100rpx;
}

.panel-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 28rpx 16rpx;
  flex-shrink: 0;
}
.panel-title {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}
.label-brand {
  font-size: 28rpx;
  font-weight: 500;
  color: #1565C0;
}
.summary {
  font-size: 22rpx;
  color: #66736f;
}
.panel-arrow {
  font-size: 24rpx;
  color: #66736f;
}

.panel-body {
  flex: 1;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  padding: 0 20rpx 16rpx;
}

/* ── 筛选行 ── */
.filter-row {
  margin-bottom: 14rpx;
  padding: 0 20rpx;
}
.search-wrap {
  display: flex;
  align-items: center;
  background: #f0f4f8;
  border: 1rpx solid #c5d4e8;
  border-radius: 16rpx;
  padding: 0 20rpx;
  height: 72rpx;
}
.search-wrap .input {
  flex: 1;
  font-size: 28rpx;
  color: #14231f;
  background: transparent;
  border: none;
  padding: 0;
  min-width: 0;
}
.picker-display {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #f0f4f8;
  border: 1rpx solid #c5d4e8;
  border-radius: 16rpx;
  padding: 16rpx 20rpx;
  font-size: 26rpx;
  color: #14231f;
}
.picker-arrow {
  color: #66736f;
  font-size: 30rpx;
}
.slider-label {
  display: flex;
  justify-content: space-between;
  font-size: 24rpx;
  color: #30433d;
  margin-bottom: 4rpx;
}
.slider-value {
  color: #1565C0;
  font-weight: 500;
}

/* ── 评分图例 ── */
.legend-bar {
  margin-bottom: 14rpx;
  padding: 16rpx 20rpx;
  background: #f8fafc;
  border-radius: 14rpx;
  border: 1rpx solid #e3eaf2;
  margin-left: 20rpx;
  margin-right: 20rpx;
}
.legend-title {
  font-size: 22rpx;
  font-weight: 500;
  color: #30433d;
  display: block;
  margin-bottom: 10rpx;
}
.legend-inline {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx 16rpx;
}
.legend-dot {
  display: flex;
  align-items: center;
  gap: 6rpx;
  font-size: 20rpx;
  color: #66736f;
}
.dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  flex-shrink: 0;
  box-shadow: 0 0 0 2rpx rgba(255,255,255,.9);
}

/* ── 钓点列表 ── */
.spot-list {
  flex: 1;
  overflow-y: auto;
}
.spot-card {
  background: #ffffff;
  border: 1rpx solid #e3eaf2;
  border-radius: 18rpx;
  padding: 20rpx;
  margin-bottom: 12rpx;
}
.spot-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
  gap: 10rpx;
}
.spot-left {
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex: 1;
  min-width: 0;
}
/* 评分颜色徽章（列表卡片） */
.score-badge {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18rpx;
  font-weight: 700;
  color: #ffffff;
  flex-shrink: 0;
  box-shadow: 0 0 0 3rpx rgba(255,255,255,.9), 0 0 0 5rpx rgba(10,25,41,.08);
}
.spot-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #14231f;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.spot-score {
  font-size: 22rpx;
  color: #1565C0;
  white-space: nowrap;
  flex-shrink: 0;
}
.spot-meta {
  font-size: 20rpx;
  color: #66736f;
  margin-bottom: 10rpx;
  padding-left: 46rpx;
}

/* ── 标签 ── */
.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 4rpx;
  padding-left: 46rpx;
}
.tag {
  font-size: 22rpx;
  font-weight: 500;
  color: #0D47A1;
  background: #E3F2FD;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
}
.tag-gray {
  color: #596863;
  background: #eceff1;
}

.empty-tip {
  text-align: center;
  font-size: 26rpx;
  color: #66736f;
  padding: 40rpx 0;
}

/* ── 详情弹层 ── */
.detail-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.35);
  z-index: 30;
}
.detail-sheet {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #ffffff;
  border-radius: 28rpx 28rpx 0 0;
  padding: 36rpx 28rpx 60rpx;
  z-index: 40;
  max-height: 75vh;
  overflow-y: auto;
  box-shadow: 0 -4rpx 24rpx rgba(10, 25, 41, 0.22);
}
.detail-close {
  position: absolute;
  top: 24rpx;
  right: 28rpx;
  font-size: 32rpx;
  color: #66736f;
  padding: 10rpx;
}

/* 详情：名称 + 评分徽章 */
.detail-name-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-bottom: 24rpx;
  padding-right: 60rpx;
}
.score-badge-lg {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 700;
  color: #ffffff;
  flex-shrink: 0;
  box-shadow: 0 0 0 3rpx rgba(255,255,255,.9), 0 0 0 5rpx rgba(10,25,41,.08);
}
.detail-name {
  font-size: 36rpx;
  font-weight: 500;
  color: #14231f;
  flex: 1;
}

.detail-row {
  display: flex;
  align-items: center;
  padding: 14rpx 0;
  border-bottom: 1rpx solid #eef2f7;
}
.detail-row--col {
  flex-direction: column;
  align-items: flex-start;
  gap: 10rpx;
}
.detail-label {
  font-size: 24rpx;
  color: #66736f;
  width: 160rpx;
  flex-shrink: 0;
}
.detail-val {
  font-size: 26rpx;
  color: #14231f;
  flex: 1;
}
.detail-val.highlight {
  color: #1565C0;
  font-weight: 500;
}

/* ── 分月评分芯片 ── */
.month-scores {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  width: 100%;
}
.month-chip {
  display: flex;
  align-items: center;
  gap: 6rpx;
  background: #f0f4f8;
  border-radius: 12rpx;
  padding: 8rpx 16rpx;
}
.month-label {
  font-size: 22rpx;
  font-weight: 500;
  color: #30433d;
}
.month-val {
  font-size: 22rpx;
  font-weight: 700;
  color: #1565C0;
}

/* ── 视频来源列表 ── */
.source-list {
  width: 100%;
}
.source-item {
  padding: 16rpx;
  margin-bottom: 10rpx;
  background: #f8fafc;
  border-radius: 12rpx;
  border: 1rpx solid #eef2f7;
}
.source-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 6rpx;
}
.source-author {
  font-size: 24rpx;
  font-weight: 500;
  color: #14231f;
}
.source-score {
  font-size: 20rpx;
  color: #1565C0;
  font-weight: 500;
}
.source-title {
  font-size: 22rpx;
  color: #66736f;
  line-height: 1.45;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  margin-bottom: 8rpx;
}
.source-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.source-time {
  font-size: 20rpx;
  color: #999;
}
.source-link {
  font-size: 22rpx;
  color: #1565C0;
  font-weight: 500;
}
.source-more {
  font-size: 22rpx;
  color: #999;
  text-align: center;
  padding: 16rpx;
}
